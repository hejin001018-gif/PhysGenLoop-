{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pavg.local/schemas/critic_trace.schema.json",
  "title": "PAVG Critic Execution Trace",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "metadata",
    "nodes",
    "outcome",
    "warnings"
  ],
  "properties": {
    "schema_version": {
      "const": "pavg-critic-trace/v1"
    },
    "metadata": {
      "type": "object"
    },
    "nodes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/node"
      }
    },
    "outcome": {
      "type": "object"
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "node": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sequence",
        "node_id",
        "label",
        "parent_id",
        "source_nodes",
        "status",
        "elapsed_ms",
        "inputs",
        "outputs",
        "warnings",
        "error"
      ],
      "properties": {
        "sequence": {
          "type": "integer",
          "minimum": 1
        },
        "node_id": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "parent_id": {
          "type": ["string", "null"]
        },
        "source_nodes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "status": {
          "enum": ["completed", "skipped", "degraded", "error"]
        },
        "elapsed_ms": {
          "type": "number",
          "minimum": 0
        },
        "inputs": {
          "type": "object"
        },
        "outputs": {
          "type": "object"
        },
        "warnings": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "error": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/error"
            }
          ]
        }
      }
    },
    "error": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "message"],
      "properties": {
        "type": {
          "type": "string",
          "minLength": 1
        },
        "message": {
          "type": "string",
          "maxLength": 300
        }
      }
    }
  }
}
