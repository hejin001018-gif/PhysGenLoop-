{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pavg.local/schemas/sample.schema.json",
  "title": "PAVG Sample Annotation",
  "description": "单样本目录的元数据 + 标注。对齐 README §数据集与标注规范。",
  "type": "object",
  "required": ["schema_version", "sample_id", "source", "is_physical", "video_path"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {"type": "string", "const": "1.0"},
    "sample_id": {"type": "string", "pattern": "^[a-zA-Z0-9_\\-]+$"},
    "source": {
      "type": "string",
      "enum": [
        "kubric_synthetic",
        "blender_synthetic",
        "physion",
        "intphys2",
        "hunyuan_generated",
        "real_video"
      ]
    },
    "is_physical": {"type": "boolean"},
    "video_path": {"type": "string"},
    "scene_template": {"type": "string"},
    "seed": {"type": "integer"},
    "fps": {"type": "number", "exclusiveMinimum": 0},
    "num_frames": {"type": "integer", "minimum": 1},
    "resolution": {
      "type": "object",
      "properties": {
        "width": {"type": "integer"},
        "height": {"type": "integer"}
      },
      "required": ["width", "height"]
    },
    "objects": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "category"],
        "properties": {
          "id": {"type": "string"},
          "category": {"type": "string"},
          "role": {"type": "string", "enum": ["actor", "support", "obstacle", "container", "other"]}
        }
      }
    },
    "violations": {
      "type": "array",
      "items": {"$ref": "#/$defs/violation"}
    },
    "provenance": {
      "type": "object",
      "properties": {
        "engine": {"type": "string"},
        "engine_version": {"type": "string"},
        "renderer": {"type": "string"},
        "created_at": {"type": "string", "format": "date-time"},
        "pipeline_version": {"type": "string"}
      }
    }
  },
  "$defs": {
    "violation": {
      "type": "object",
      "required": ["category", "object", "start_frame", "end_frame"],
      "properties": {
        "category": {
          "type": "string",
          "enum": [
            "reverse_gravity",
            "floating",
            "premature_rebound",
            "no_response_on_contact",
            "wall_penetration",
            "floor_penetration",
            "object_interpenetration",
            "vanish",
            "teleport",
            "identity_switch"
          ]
        },
        "object": {"type": "string"},
        "start_frame": {"type": "integer", "minimum": 0},
        "peak_frame": {"type": "integer", "minimum": 0},
        "end_frame": {"type": "integer", "minimum": 0},
        "critical_frames": {
          "type": "array",
          "items": {"type": "integer", "minimum": 0}
        },
        "expected_rule": {"type": "string"},
        "repair_instruction": {"type": "string"}
      }
    }
  }
}
