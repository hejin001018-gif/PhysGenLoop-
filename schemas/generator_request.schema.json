{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pavg.local/schemas/generator_request.schema.json",
  "title": "PAVG Generator Request (HunyuanVideo-1.5)",
  "description": "HunyuanVideo 调用契约。对齐 README §Agentic 生成闭环 §生成接口。",
  "type": "object",
  "required": ["prompt", "seed", "resolution", "num_frames", "output_path"],
  "additionalProperties": false,
  "properties": {
    "prompt": {"type": "string", "minLength": 1},
    "seed": {"type": "integer"},
    "resolution": {"type": "string", "enum": ["480p", "720p", "1080p"]},
    "num_frames": {"type": "integer", "minimum": 1},
    "num_inference_steps": {"type": "integer", "minimum": 1, "default": 50},
    "image_path": {"type": ["string", "null"], "description": "I2V 首帧；T2V 为 null"},
    "output_path": {"type": "string"},
    "physics_hint": {
      "type": ["string", "null"],
      "description": "Repair Agent L1 注入的物理提示"
    },
    "repair_context": {
      "type": ["object", "null"],
      "description": "Repair Agent L2 局部重生上下文",
      "properties": {
        "critical_frames": {"type": "array", "items": {"type": "integer", "minimum": 0}},
        "object_masks": {"type": "array", "items": {"type": "string"}},
        "strategy": {"type": "string", "enum": ["prompt_only", "local_inpaint", "full_regen"]}
      }
    },
    "generation_meta": {
      "type": "object",
      "properties": {
        "attempt": {"type": "integer", "minimum": 0},
        "parent_video_path": {"type": ["string", "null"]},
        "loop_round": {"type": "integer", "minimum": 0}
      }
    }
  }
}
