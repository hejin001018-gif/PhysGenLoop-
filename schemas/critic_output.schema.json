{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pavg.local/schemas/critic_output.schema.json",
  "title": "PAVG Physics Critic Output",
  "description": "Physics Critic 输出。对齐 README §Physics Critic §推荐输出。",
  "type": "object",
  "required": ["schema_version", "is_physical", "physics_score", "confidence", "violations"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {"type": "string", "const": "1.0"},
    "is_physical": {"type": "boolean"},
    "physics_score": {"type": "number", "minimum": 0, "maximum": 1},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "score_breakdown": {
      "type": "object",
      "description": "physics_score = w1·rule + w2·refsim + w3·vlm_same + w4·vlm_diff",
      "properties": {
        "rule": {"type": "number", "minimum": 0, "maximum": 1},
        "refsim": {"type": "number", "minimum": 0, "maximum": 1},
        "vlm_same": {"type": "number", "minimum": 0, "maximum": 1},
        "vlm_diff": {"type": "number", "minimum": 0, "maximum": 1}
      }
    },
    "violations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["object", "category", "start_frame", "end_frame", "reason"],
        "properties": {
          "object": {"type": "string"},
          "category": {"type": "string"},
          "start_frame": {"type": "integer", "minimum": 0},
          "peak_frame": {"type": "integer", "minimum": 0},
          "end_frame": {"type": "integer", "minimum": 0},
          "critical_frames": {
            "type": "array",
            "items": {"type": "integer", "minimum": 0}
          },
          "reason": {"type": "string"},
          "repair_instruction": {"type": "string"},
          "evidence": {
            "type": "object",
            "properties": {
              "rules": {"type": "array", "items": {"type": "string"}},
              "detector_score": {"type": "number", "minimum": 0, "maximum": 1},
              "vlm_score": {"type": "number", "minimum": 0, "maximum": 1},
              "refsim_deviation": {"type": "number", "minimum": 0}
            }
          }
        }
      }
    },
    "diagnostics": {
      "type": "object",
      "description": "PQSG 细粒度诊断（objects / actions / physical_laws 三层通过率）",
      "properties": {
        "pqsg_objects": {"type": "number", "minimum": 0, "maximum": 1},
        "pqsg_actions": {"type": "number", "minimum": 0, "maximum": 1},
        "pqsg_laws": {"type": "number", "minimum": 0, "maximum": 1}
      }
    },
    "model_versions": {
      "type": "object",
      "properties": {
        "detector": {"type": "string"},
        "tracker": {"type": "string"},
        "vlm_same": {"type": "string"},
        "vlm_diff": {"type": "string"},
        "refsim_engine": {"type": "string"}
      }
    }
  }
}
