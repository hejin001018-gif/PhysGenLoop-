{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pavg.local/schemas/critic_output.schema.json",
  "title": "PAVG CriticReport 2.0",
  "description": "PAVG Physics Critic 的统一、可审计输出。",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "decision",
    "is_physical",
    "physics_score",
    "confidence",
    "coverage",
    "violations",
    "node_results",
    "score_breakdown",
    "diagnostics",
    "model_versions"
  ],
  "properties": {
    "schema_version": {"const": "2.0"},
    "decision": {"enum": ["physical", "violation", "unknown"]},
    "is_physical": {"type": "boolean"},
    "physics_score": {"type": "number", "minimum": 0, "maximum": 1},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "coverage": {"type": "number", "minimum": 0, "maximum": 1},
    "score_breakdown": {
      "type": "object",
      "additionalProperties": {"type": "number", "minimum": 0, "maximum": 1}
    },
    "violations": {
      "type": "array",
      "items": {"$ref": "#/$defs/violation"}
    },
    "graph_evaluation": {
      "type": "object",
      "additionalProperties": true
    },
    "node_results": {
      "type": "array",
      "items": {"$ref": "#/$defs/node_result"}
    },
    "diagnostics": {"type": "object", "additionalProperties": true},
    "model_versions": {
      "type": "object",
      "additionalProperties": {"type": "string"}
    },
    "evidence_bundles": {
      "type": "array",
      "items": {"type": "object", "additionalProperties": true}
    }
  },
  "$defs": {
    "violation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "object",
        "category",
        "start_frame",
        "peak_frame",
        "end_frame",
        "critical_frames",
        "reason",
        "repair_instruction",
        "evidence"
      ],
      "properties": {
        "object": {"type": "string"},
        "category": {"type": "string"},
        "start_frame": {"type": "integer", "minimum": 0},
        "peak_frame": {"type": "integer", "minimum": 0},
        "end_frame": {"type": "integer", "minimum": 0},
        "critical_frames": {
          "type": "array",
          "items": {"type": "integer", "minimum": 0}
        },
        "reason": {"type": "string"},
        "repair_instruction": {"type": "string"},
        "evidence": {"type": "object", "additionalProperties": true}
      }
    },
    "node_result": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "node_id",
        "category",
        "status",
        "confidence",
        "reason",
        "verifier",
        "critical_frames",
        "rule_ids",
        "blocked_by",
        "evidence"
      ],
      "properties": {
        "node_id": {"type": "string"},
        "category": {"enum": ["object", "action", "physics"]},
        "status": {"enum": ["yes", "no", "blocked", "unknown"]},
        "direct_score": {"type": "number", "minimum": 0, "maximum": 1},
        "confidence": {"type": "number", "minimum": 0, "maximum": 1},
        "reason": {"type": "string"},
        "verifier": {"type": "string"},
        "critical_frames": {"type": "array", "items": {"type": "integer"}},
        "rule_ids": {"type": "array", "items": {"type": "string"}},
        "blocked_by": {"type": "array", "items": {"type": "string"}},
        "evidence": {"type": "object", "additionalProperties": true}
      }
    }
  }
}
