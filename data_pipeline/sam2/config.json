{
  "project_version": "1.0.0",
  "dataset": {
    "name": "DAVIS 2017 trainval 480p",
    "url": "https://data.vision.ee.ethz.ch/csergi/share/davis/DAVIS-2017-trainval-480p.zip",
    "archive": "downloads/DAVIS-2017-trainval-480p.zip",
    "fps": 24
  },
  "sam2": {
    "repository": "external/sam2",
    "checkpoint": "downloads/sam2.1_hiera_large.pt",
    "model_config": "configs/sam2.1/sam2.1_hiera_l.yaml",
    "device": "cuda",
    "prompt": "fixed non-adaptive boxes at 0%, 33%, and 67% of the sequence; non-prompt frames are audited separately",
    "mask_threshold": 0.0
  },
  "inpainting": {
    "engine": "ProPainter",
    "repository": "external/ProPainter",
    "mask_dilation_pixels": 15,
    "mask_vertical_shadow_extension_pixels": 6
  },
  "encoding": {
    "video_codec": "libx264",
    "pixel_format": "yuv420p",
    "crf": 18,
    "preset": "medium",
    "gop_seconds": 2
  },
  "sequences": [
    {
      "id": "soccerball",
      "order": 1,
      "anomaly": "midair_hover",
      "onset_fraction": 0.42,
      "shadow_mode": "none",
      "description": "The moving ball stops translating in mid-air while the scene continues."
    },
    {
      "id": "drift-straight",
      "order": 2,
      "anomaly": "instant_teleport",
      "onset_fraction": 0.48,
      "dx_fraction": 0.16,
      "dy_fraction": -0.04,
      "shadow_mode": "synthetic_ground",
      "shadow_repair_extension_pixels": 32,
      "shadow_opacity": 0.30,
      "description": "The tracked car undergoes an instantaneous discontinuous displacement."
    },
    {
      "id": "car-turn",
      "order": 3,
      "anomaly": "gravity_reversal",
      "onset_fraction": 0.40,
      "upward_acceleration_fraction": 0.28,
      "shadow_mode": "synthetic_ground",
      "shadow_repair_extension_pixels": 32,
      "shadow_opacity": 0.28,
      "description": "The car accelerates upward against gravity while its ground shadow remains on the road and weakens."
    }
  ]
}
